  "applicability": {
    "applicable_catalog_pattern": "807-NX3-S*-{LENGTH}-{ARM}-{MOUNTING}-{POWER_LOC}-{POWER_TYPE}-2-{EMERG}-Z-SO-359-HL-{SENSOR}-BL-{OPTIONS}",
    "fixed_axes": {
      "system": "807",
      "rail_type": "NX3",
      "voltage": "universal_120_277",
      "led_type": "Z",
      "lumen_output": "SO",
      "color_temperature": "359",
      "optics": "HL",
      "finish": "BL"
    },
    "covered_axes": {
      "length": {
        "values": [
          "48",
          "60",
          "72",
          "84",
          "96"
        ],
        "rationale": "Per Pattern D linear scaling. The 48\" length is the tested baseline (1276 lm / 26.5 W). All other lengths derive from the cutsheet's per-foot rates (319 lm/ft, 6.7 W/ft) published on page 9 of the spec sheet.",
        "derivation": {
          "method": "per_foot_linear_scaling",
          "baseline_axis_value": "48",
          "linear_rate": {
            "value": 319,
            "unit": "lm/ft"
          },
          "reference": "spec_sheet_page_9_performance_table",
          "note": "Lumens scale at 319 lm/ft; input power scales at 6.7 W/ft. Efficacy is constant at 49 lm/W across lengths. Derived values tabulated in photometry.declared_by_length."
        }
      },
      "mounting": {
        "values": [
          "CC",
          "T1",
          "T2",
          "T3",
          "T4",
          "T5",
          "T6",
          "Suspended"
        ],
        "rationale": "Mounting is photometrically transparent: the NX3 rail light engine and HL optic are identical across Surface (the actual tested IES mounting, per LUMINAIRE field `Surface, 48\", Surface Mount`), Cable-to-Canopy, T1-T6 Canopy, and Suspended variants. Only the mechanical mounting hardware above the rail changes, which does not affect emitted photometry."
      },
      "arm_cable_length": {
        "values": [
          "any"
        ],
        "rationale": "Arm or cable length determines only suspension drop from the ceiling and is photometrically irrelevant."
      },
      "power_location": {
        "values": [
          "XX"
        ],
        "rationale": "Power location is Remote only for the Nexa 807 family; not a true variation axis. The driver is separated from the rail up to 100 ft / 31 m away."
      },
      "power_type": {
        "values": [
          "AE",
          "AT",
          "AD",
          "AX",
          "AH",
          "AH2",
          "AEO",
          "ATO",
          "ADO",
          "AEF",
          "ATF",
          "ADF"
        ],
        "rationale": "Dimming driver protocol does not change photometric output at Standard Output tier. Some Power Types alter max drive current on HO/MO tiers, but at SO the output is driver-independent. The tested scenario's specific Power Type (XX in the LUMCAT field) is unspecified; any of these codes is covered."
      },
      "emergency_power": {
        "values": [
          "0",
          "EMBS",
          "EMBV",
          "EMBG"
        ],
        "rationale": "Emergency power packs switch the fixture to battery backup operation in a loss-of-power event; they do not affect normal-mode photometry."
      },
      "sensors": {
        "values": [
          "0",
          "OCC",
          "DL",
          "OCCDL"
        ],
        "rationale": "Integrated sensor modules affect control behavior, not emitted photometry."
      },
      "options": {
        "values": [
          "0",
          "CPP",
          "9"
        ],
        "rationale": "CPP (Chicago Plenum Power) and 9 (Cord and Plug) do not alter photometric output. CPP compliance is captured as an option-conditional attestation below rather than excluding the combination."
      }
    },
    "excluded_combinations": [
      {
        "axes": {
          "color_temperature": "RGBW",
          "length": [
            "72",
            "84",
            "96"
          ]
        },
        "reason": "RGBW output is limited to 60\" max length on Standard Output and High Output tiers. Not in scope for this record (this record is 3500K 90+ CRI static white), noted for family-level completeness."
      }
    ],
    "applicable_sku_count_estimate": 120
  },
