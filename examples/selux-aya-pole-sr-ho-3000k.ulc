{
  "applicability": {
    "applicable_catalog_pattern": "AYAP-SR-{MOUNT}-HO-{CCT}-{CORD}-{FINISH}-{VOLT}-{OPTIONS}",
    "applicable_sku_count_estimate": 4000,
    "covered_axes": {
      "cct": {
        "derivation": {
          "baseline_axis_value": "3000",
          "method": "manufacturer_lumen_multiplier",
          "multiplier_table": {
            "2200": 0.86,
            "2700": 0.93,
            "3000": 1,
            "3500": 1,
            "4000": 1.07,
            "5000": 1.07
          },
          "note": "Multiplier applied to the measured 3000K total luminous flux (5074 lm). 3000K and 3500K share multiplier 1.00; 4000K and 5000K share multiplier 1.07. 2200K and 2700K are attenuated relative to 3000K baseline. Note 2 on page 9 of the spec sheet: 2700K and 3000K meet DarkSky requirements.",
          "reference": "spec_sheet_page_9_cct_multiplier_table"
        },
        "rationale": "White CCT variance is declared on spec sheet page 9 (CCT multiplier table). The 3000K baseline is LM-79 tested at 5074 lm; other CCTs derive from the manufacturer multiplier table. The per-CCT lumen and efficacy projections are enumerated in photometry.declared_by_cct.",
        "values": [
          "2200",
          "2700",
          "3000",
          "3500",
          "4000",
          "5000"
        ]
      },
      "finish": {
        "rationale": "Finish is external polyester powder coat (Tiger Drylac certified, five-stage pretreatment, ASTM/PCI tested). The SR optic is internal and does not carry a finish-dependent glare shield, so external finish has no photometric effect. BL (Black Semi-Matte) is the tested finish in this LUMCAT.",
        "values": [
          "WH",
          "BK",
          "BL",
          "BZ",
          "SV",
          "SP"
        ]
      },
      "mounting": {
        "rationale": "Mounting variants share light engine and SR optic. `1` is Single Post Top (the tested configuration per LUMCAT). `1A` is Single Pendant and `2` is Dual Pendant; both substitute a welded aluminum pendant arm for the self-leveling fitter base but route the same light engine through the same SR optic. Photometrically equivalent; only mechanical attachment changes.",
        "values": [
          "1",
          "1A",
          "2"
        ]
      },
      "options": {
        "rationale": "DD (DALI-2 driver), TLR (7-pin NEMA twist-lock receptacle), TLRP (twist-lock photocell), and MSxx (motion sensors with orientation variants) change control behavior, not emitted photometric output. The tested LUMCAT does not carry an option suffix.",
        "values": [
          "DD",
          "TLR",
          "TLRP",
          "MS0",
          "MS1",
          "MS2",
          "MS3",
          "MS4",
          "none"
        ]
      },
      "power_cord_length": {
        "rationale": "Power cord length is the external feed from fixture to driver; it is photometrically irrelevant. The LUMCAT `AYAP-SR-1-HO-30-BL-UNV` does not carry a cord-length segment (pendant/pole-top variants order cord length separately).",
        "values": [
          "8",
          "10",
          "12",
          "14",
          "16",
          "18",
          "XX"
        ]
      },
      "voltage": {
        "derivation": {
          "baseline_axis_value": "UNV",
          "method": "regulated_driver_voltage_independence",
          "note": "347V and 480V options add step-down transformer with ~10% input power penalty; output flux is unchanged because the driver is regulated.",
          "reference": "spec_sheet_page_2_driver_specifications"
        },
        "rationale": "The LED driver is a regulated constant-current driver. Luminaire input power and light output are independent of input voltage within the driver's range. For 347V and 480V, a step-down transformer adds approximately 10% nominal wattage penalty; photometric output is unchanged.",
        "values": [
          "120",
          "240",
          "277",
          "347",
          "480",
          "UNV"
        ]
      }
    },
    "excluded_combinations": [
      {
        "axes": {
          "output": "BR"
        },
        "reason": "BR (BioRed) is a two-channel light engine alternating 630 nm BioRed LEDs with 2700K White and uses a different photometric record set; out of scope for this white-light SR + HO record."
